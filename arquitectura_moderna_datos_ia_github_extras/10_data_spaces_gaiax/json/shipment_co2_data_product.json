    "co2_kg": "decimal",
    "calculation_method": "string",
    "calculated_at": "timestamp"
  },
  "access": {
    "requires_contract": true,
    "allowed_purposes": ["sustainability_reporting", "regulatory_reporting", "partner_optimization"]
  }
}
